# Clause — Environment Configuration
# Copy this to .env and fill in actual values
# Never commit .env to git!

# === LLM APIs ===
ANTHROPIC_API_KEY=sk-ant-...     # Required only if ENRICHMENT_PROVIDER=claude
OPENAI_API_KEY=sk-...            # Required for embeddings (Step 4)

# === Ollama (local, free — no API key needed) ===
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b          # or llama3.2:3b, mistral:7b, phi4-mini, etc.

# === Enrichment Provider ===
# "ollama" → local, free (default)
# "claude" → cloud, ~$1-2 for full corpus
ENRICHMENT_PROVIDER=ollama

# === Vector Database (Qdrant) ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=clause_chunks

# === Graph Database (Neo4j) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=clausepassword

# === Reranker API ===
COHERE_API_KEY=...

# === Observability (Optional) ===
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=clause
LANGCHAIN_TRACING_V2=true

# === Model Configuration (Locked — do not change) ===
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
GENERATION_MODEL=claude-sonnet-4-20250514
CONTEXTUALIZATION_MODEL=claude-haiku-20240307

# === Retrieval Parameters (Tunable) ===
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
MAX_AGENT_ITERATIONS=3

# === Chunking Parameters (Locked) ===
CHILD_CHUNK_SIZE=256
PARENT_CHUNK_SIZE=1024
CHILD_CHUNK_OVERLAP=20
